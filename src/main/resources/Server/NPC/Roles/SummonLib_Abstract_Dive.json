{
  "$Comment": "SummonLib - DIVE Abstract (Idle / Move / Attack). Minimal + stable.",
  "Type": "Generic",
  "StartState": "Idle",
  "Parameters": {
    "Appearance": {
      "Value": "Fish"
    },
    "MaxHealth": {
      "Value": 15
    },
    "NameTranslationKey": {
      "Value": "server.npcRoles.Summon.name"
    },
    "WanderRadius": {
      "Value": 10
    },
    "AttackAnimationId": {
      "Value": "Attack"
    }
  },
  "Appearance": {
    "Compute": "Appearance"
  },
  "MaxHealth": {
    "Compute": "MaxHealth"
  },
  "NameTranslationKey": {
    "Compute": "NameTranslationKey"
  },
  "BusyStates": [
    "Idle"
  ],
  "MotionControllerList": [
    {
      "$Comment": "Dive controller defaults: tune later. This is meant to be safe/neutral.",
      "Type": "Dive",
      "Gravity": 10.0,
      "MaxHorizontalSpeed": 10.0,
      "MaxVerticalSpeed": 6.0,
      "Acceleration": 5.0,
      "MaxFallSpeed": 9.0,
      "MaxSinkSpeed": 9.0,
      "MaxRotationSpeed": 360.0,
      "MaxMoveTurnAngle": 110.0,
      "MinDiveDepth": 0.5,
      "MaxDiveDepth": 10.0,
      "MinWaterDepth": 2.0,
      "MaxWaterDepth": 40.0,
      "MinDepthAboveGround": 0.5,
      "MinDepthBelowSurface": 0.5,
      "SwimDepth": 0.5,
      "SinkRatio": 0.5,
      "FastDiveThreshold": 0.75,
      "DesiredDepthWeight": 0.5
    }
  ],
  "Instructions": [
    {
      "Instructions": [
        {
          "Sensor": {
            "Type": "State",
            "State": "Idle"
          },
          "Instructions": [
            {
              "Sensor": {
                "Type": "State",
                "State": ".Default"
              },
              "Actions": [
                {
                  "Type": "PlayAnimation",
                  "Slot": "Status"
                },
                {
                  "Type": "State",
                  "State": ".Move"
                }
              ]
            },
            {
              "Sensor": {
                "Type": "State",
                "State": ".Attack"
              },
              "Actions": [
                {
                  "Type": "PlayAnimation",
                  "Slot": "Status"
                },
                {
                  "Type": "State",
                  "State": ".AttackWait"
                }
              ]
            },
            {
              "Sensor": {
                "Type": "State",
                "State": ".AttackWait"
              },
              "Instructions": [
                {
                  "Sensor": {
                    "Type": "Animation",
                    "Slot": "Status",
                    "AnimationId": {
                      "Compute": "AttackAnimationId"
                    },
                    "Once": false
                  }
                },
                {
                  "Sensor": {
                    "Type": "State",
                    "State": ".Default"
                  },
                  "Actions": [
                    {
                      "Type": "State",
                      "State": ".Move"
                    }
                  ]
                }
              ]
            },
            {
              "Sensor": {
                "Type": "State",
                "State": ".Move"
              },
              "Instructions": [
                {
                  "Sensor": {
                    "Type": "Leash",
                    "Range": {
                      "Compute": "WanderRadius"
                    },
                    "Once": false
                  },
                  "BodyMotion": {
                    "Type": "Seek",
                    "SlowDownDistance": 1.5,
                    "StopDistance": 1.0,
                    "RelativeSpeed": 0.6
                  }
                },
                {
                  "Sensor": {
                    "Type": "State",
                    "State": ".Default"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
