  "Instructions": [
    {
      "Instructions": [
        {
          "Sensor": {
            "Type": "State",
            "State": "Idle"
          },
          "Instructions": [
            {
              "$Comment": "Follow leash when idle (leash updated from code).",
              "Continue": false,
              "Sensor": {
                "Type": "Leash",
                "Range": {
                  "Compute": "FollowLeashRange"
                }
              },
              "HeadMotion": {
                "Type": "Nothing"
              },
              "BodyMotion": {
                "Type": "Seek",
                "SlowDownDistance": 3.0,
                "StopDistance": 1.4,
                "RelativeSpeed": 0.7
              }
            },
            {
              "$Comment": "Auto-enter Combat when there is a target.",
              "Continue": false,
              "Sensor": {
                "Type": "Target",
                "Range": 999999
              },
              "Actions": [
                {
                  "Type": "State",
                  "State": "Combat"
                }
              ]
            },
            {
              "$Comment": "Fallback only if nothing else matched.",
              "HeadMotion": {
                "Type": "Nothing"
              },
              "BodyMotion": {
                "Type": "Nothing"
              }
            }
          ]
        },
        {
          "Sensor": {
            "Type": "State",
            "State": "Combat"
          },
          "Instructions": [
            {
              "$Comment": "If target is gone, return to Idle.",
              "Continue": false,
              "Sensor": {
                "Type": "Not",
                "Sensor": {
                  "Type": "Target"
                }
              },
              "Actions": [
                {
                  "Type": "ReleaseTarget"
                },
                {
                  "Type": "State",
                  "State": "Idle"
                }
              ]
            },
            {
              "$Comment": "Keep leash anchored to current target (altitude helper).",
              "Continue": true,
              "Sensor": {
                "Type": "Target",
                "Range": 999999
              },
              "Actions": [
                {
                  "Type": "SetLeashPosition",
                  "ToTarget": true
                }
              ]
            },
            {
              "$Comment": "Attack when in range + LoS.",
              "Continue": false,
              "Sensor": {
                "Type": "Target",
                "Range": {
                  "Compute": "AttackDistance"
                },
                "Filters": [
                  {
                    "Type": "LineOfSight"
                  }
                ]
              },
              "ActionsBlocking": true,
              "Actions": [
                {
                  "Type": "Attack",
                  "Attack": {
                    "Compute": "Attack"
                  },
                  "AttackPauseRange": {
                    "Compute": "AttackPauseRange"
                  }
                }
              ],
              "HeadMotion": {
                "Type": "Aim"
              },
              "BodyMotion": {
                "Type": "WanderInCircle",
                "Radius": {
                  "Compute": "OrbitRadius"
                },
                "MaxHeadingChange": 60,
                "RelativeSpeed": 0.25
              }
            },
            {
              "$Comment": "Chase target directly.",
              "Continue": false,
              "Sensor": {
                "Type": "Target",
                "Range": 999999
              },
              "HeadMotion": {
                "Type": "Watch"
              },
              "BodyMotion": {
                "Type": "Seek",
                "SlowDownDistance": 3.5,
                "StopDistance": {
                  "Compute": "ChaseStopDistance"
                },
                "RelativeSpeed": 0.7
              }
            }
          ]
        }
      ]
    }
  ],
