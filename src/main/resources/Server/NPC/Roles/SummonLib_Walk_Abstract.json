    {
      "Instructions": [
        {
          "Sensor": {
            "Type": "State",
            "State": "Idle"
          },
          "Instructions": [
            {
              "$Comment": "Follow leash when idle (leash updated from code).",
              "Continue": false,
              "Sensor": {
                "Type": "Leash",
                "Range": {
                  "Compute": "FollowLeashRange"
                }
              },
              "HeadMotion": {
                "Type": "Nothing"
